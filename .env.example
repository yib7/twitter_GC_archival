# Port for the development server (default: 8765)
GCA_PORT=8765

# Path to personal data directory for build scripts (default: ./personal_data)
# Set this to override the default location when building the archive
GCA_PERSONAL=./personal_data

# Base URL for Playwright tests (default: http://127.0.0.1:8765)
# Set this to test against a different server
PLAYWRIGHT_BASE_URL=http://127.0.0.1:8765

# CI environment indicator
# Set to any truthy value when running in CI to use existing servers
CI=
