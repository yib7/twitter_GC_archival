# ============================================================================
#  PRIVATE DATA — never commit. This repo ships only synthetic sample data.
# ============================================================================

# All real, user-specific data lives here: config.json, the built data.js,
# local.js (names/pfps/me/GC), copied media, and profile/group photos.
# Written by the setup wizard (setup.html) — never commit.
# Glob covers backups too (e.g. personal_data.REAL/ created during testing).
personal_data*/

# Built archive (real messages) — regenerate with `node scripts/build.js`
data.js

# Raw Twitter/X exports (full content + headers, 1:1 + group)
direct-messages.js
direct-messages-group.js
direct-message-headers.js
direct-message-group-headers.js
direct-messages*.js
direct-message-*.js

# Media folders (real photos & videos)
direct_messages_media/
direct_messages_group_media/
profile_pictures/
gc_photo.jpg

# Private local overrides (real names / profile pictures)
names.local.js

# Packaged export archives (multi-GB) — never commit
*.zip

# Raw export staging folder (real export files dropped here before setup)
exports/

# Local environment overrides (the app needs none, but never commit one if added)
.env
.env.*
# But DO track the example file so users know what vars are available
!.env.example

# Editor / IDE / tool / AI session files — never published
.claude/
CLAUDE.md
.autopilot/
.superpowers/
.vscode/
.idea/

# Dependencies
node_modules/

# Playwright test artifacts
test-results/
playwright-report/

# Internal planning brief (references real ids / private data). Bare pattern, so
# it matches PLAN.md at any depth.
PLAN.md

# Brainstorming / design specs (work-in-progress notes, reference private data)
docs/superpowers/

# Ship checklist (internal planning doc)
final.md

# Internal model-usage planning note (references the project's private roadmap)
fable_5_plan.md

# Internal audit report snapshots (superseded once findings are triaged into
# .autopilot/DECISIONS.md and docs/superpowers/specs/)
NEW_UPDATES.md

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# ============================================================================
#  Explicitly KEEP the synthetic, publishable sample (negate the broad ignore)
# ============================================================================
!data.sample.js
!sample_media/
